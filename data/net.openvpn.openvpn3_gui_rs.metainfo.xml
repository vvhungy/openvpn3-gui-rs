<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>net.openvpn.openvpn3_gui_rs</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>
  <name>OpenVPN3 GUI</name>
  <summary>System tray indicator for OpenVPN3 VPN tunnels</summary>

  <description>
    <p>
      A system tray application for managing OpenVPN3 VPN tunnels on Linux.
      Written in Rust with GTK4 for better performance and lower memory usage
      compared to the Python version.
    </p>
    <p>Features:</p>
    <ul>
      <li>System tray icon showing connection status</li>
      <li>VPN configuration management (import, remove)</li>
      <li>Session management (connect, disconnect, pause, resume)</li>
      <li>Desktop notifications for connection events</li>
      <li>Secure credential storage via Secret Service</li>
      <li>Automatic reconnection on startup</li>
      <li>Multiple VPN configuration support</li>
    </ul>
  </description>

  <launchable type="desktop-id">net.openvpn.openvpn3_gui_rs.desktop</launchable>

  <screenshots>
    <screenshot type="default">
      <caption>System tray icon showing connected status</caption>
      <image type="source" width="256" height="256">https://raw.githubusercontent.com/vvhungy/openvpn3-gui-rs/main/data/screenshots/tray-icon.png</image>
    </screenshot>
    <screenshot>
      <caption>Connection menu with VPN configurations</caption>
      <image type="source" width="400" height="300">https://raw.githubusercontent.com/vvhungy/openvpn3-gui-rs/main/data/screenshots/menu.png</image>
    </screenshot>
  </screenshots>

  <url type="homepage">https://github.com/vvhungy/openvpn3-gui-rs</url>
  <url type="bugtracker">https://github.com/vvhungy/openvpn3-gui-rs/issues</url>
  <url type="vcs-browser">https://github.com/vvhungy/openvpn3-gui-rs</url>

  <provides>
    <binary>openvpn3-gui-rs</binary>
  </provides>

  <requires>
    <display_length compare="ge">360</display_length>
  </requires>

  <recommends>
    <control>pointing</control>
    <control>keyboard</control>
  </recommends>

  <content_rating type="oars-1.1" />

  <releases>
    <release version="0.2.0" date="2026-04-03">
      <description>
        <p>Rewrite in Rust with GTK4</p>
        <ul>
          <li>Significantly improved startup time</li>
          <li>Reduced memory usage</li>
          <li>Native GTK4 integration</li>
